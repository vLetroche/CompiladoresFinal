#NErro sintático: 'Inesperado OPBool'

:DEC
parametro:INT
fatorial:INT

:PROG 
# Calcula o fatorial de um número inteiro
LER parametro

SE (parametro == 0) ENTAO fatorial := 1
SENAO fatorial := parametro 

ENQTO (parametro > 1) E OU parametro - 1 >1
 INI
  fatorial := (fatorial * (parametro - 1)) 
  parametro := parametro - 1
 FIM
IMPRIMIR fatorial
IMPRIMIR "Oi"
